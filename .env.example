# ---------------------------------------------------------------------------
# Planix environment variables (example)
#
# Real values live in Coolify's secret store and are NEVER committed.
# Copy this file to .env for local development only.
# ---------------------------------------------------------------------------

# --- API ---
API_PORT=3000
NODE_ENV=development

# --- PostgreSQL (all datetimes stored UTC / TIMESTAMPTZ) ---
# Local dev tip: if you created the DB as the postgres superuser, use:
#   DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/planix
DATABASE_URL=postgres://planix:planix@localhost:5432/planix
PGHOST=localhost
PGPORT=5432
PGUSER=planix
PGPASSWORD=planix
PGDATABASE=planix

# --- Azure AD SSO (internal users) ---
AZURE_AD_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_AD_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Audience the API expects on incoming Azure AD access tokens
AZURE_AD_API_AUDIENCE=api://planix

# --- JWT (Planix-issued tokens for both internal and portal sessions) ---
JWT_SECRET=change-me-in-coolify-secret-store
JWT_ACCESS_TTL=900            # seconds (15 min)
JWT_REFRESH_TTL=2592000       # seconds (30 days)

# --- Customer portal password hashing ---
BCRYPT_ROUNDS=12

# --- Garage object storage (S3-compatible) ---
GARAGE_ENDPOINT=http://localhost:3900
GARAGE_ACCESS_KEY=planix-key
GARAGE_SECRET_KEY=change-me
GARAGE_REGION=garage

# --- Email (CHR internal SMTP/Exchange via Nodemailer) ---
SMTP_HOST=smtp.chrsolutions.com
SMTP_PORT=587
SMTP_USER=planix@chrsolutions.com
SMTP_PASS=change-me

# --- AI Insights (server-side only — never exposed to frontend) ---
ANTHROPIC_API_KEY=change-me
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Web (build-time, Vite) ---
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_AZURE_AD_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_AZURE_AD_TENANT_ID=00000000-0000-0000-0000-000000000000
