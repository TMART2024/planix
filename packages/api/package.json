{
  "name": "@planix/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "migrate": "tsx src/migrate.ts up",
    "migrate:rollback": "tsx src/migrate.ts down",
    "migrate:status": "tsx src/migrate.ts status"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@fastify/cors": "^10.0.1",
    "@planix/shared": "*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "jose": "^5.9.6",
    "kysely": "^0.27.5",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.10",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2"
  }
}
